# SleepMedic Distribution Service
# Copy to .env and fill in values

# Resend (free: 3000 emails/month) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=SleepMedic <blog@sleepmedic.co>

# Admin key for webhook/subscriber list access
ADMIN_KEY=generate-a-random-string-here

# Twitter/X (optional) - https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Server
PORT=3847
